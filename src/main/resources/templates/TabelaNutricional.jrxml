	<queryString>
            <![CDATA[SELECT a.*, b.tabCodigo, b.tabPorcao, b.tabValorEnergeticoPorcao, b.tabTotalColheres, b.tabUnidadeMedidasColheres, b.undCodigo, b.tabTotalPorcao, c.tneCodigo, c.tneValor, c.eleCodigo, d.undNome, e.fabNome, e.fabEndereco, e.fabContato, f.eleNome, f.eleOrdem, f.eleValorRecomendado FROM produto a INNER JOIN tabelanutricional b ON a.proCodigo = b.proCodigo LEFT JOIN tabnutelemento c ON b.tabCodigo = c.tabCodigo INNER JOIN unidademedida d ON b.undCodigo = d.undCodigo LEFT JOIN elemento f ON c.eleCodigo = f.eleCodigo INNER JOIN fabricante e ON a.fabCodigo = e.fabCodigo WHERE b.tabCodigo = $P{codigo}]]>
        </queryString>
